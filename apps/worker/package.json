{
  "name": "@sharehtml/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "CLOUDFLARE_ENV=production vite build && wrangler deploy --env production",
    "deploy:quick": "wrangler deploy --env production",
    "deploy:dev": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "setup": "bun scripts/setup.ts",
    "setup:secrets": "bun scripts/setup-secrets.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.9",
    "@sharehtml/shared": "workspace:*",
    "hono": "^4.12.19",
    "jose": "^6.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@cloudflare/workers-types": "^4.20260518.1",
    "@playwright/test": "^1.53.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  }
}
